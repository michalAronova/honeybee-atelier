---
import NavCartButton from "./NavCartButton.tsx";
const { active = "" } = Astro.props;
const links = [
  { href: "/", label: "Home", key: "home" },
  { href: "/showcase", label: "Cakes", key: "showcase" },
  { href: "/build", label: "Build Your Own", key: "build" },
  { href: "/catering", label: "Catering", key: "catering" },
  { href: "/blog", label: "Journal", key: "blog" },
  { href: "/about", label: "About", key: "about" },
  { href: "/contact", label: "Contact", key: "contact" },
];
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a href="/" class="brand" aria-label="Honeybee Atelier home">
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l7 4v8l-7 4-7-4V6z M12 2v20 M5 6l7 4 7-4 M5 14l7-4 7 4" fill="none" stroke="var(--color-primary)" stroke-width="1.3" stroke-linejoin="round"/></svg>
      Honeybee Atelier
    </a>
    <nav class="nav" id="nav" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} aria-current={active === l.key ? "page" : undefined}>{l.label}</a>
      ))}
    </nav>
    <div class="header-actions">
      <NavCartButton client:only="react" />
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>
<script>
  const t = document.getElementById("navToggle");
  const n = document.getElementById("nav");
  t?.addEventListener("click", () => {
    const open = n?.classList.toggle("open");
    t.setAttribute("aria-expanded", String(!!open));
  });
</script>
