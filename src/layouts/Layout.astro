---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/CartDrawer.tsx";

interface Props {
  title?: string;
  description?: string;
  active?: string;
  jsonLd?: object[];
  stickyBar?: boolean;
  manualHead?: boolean;
  preloadImg?: { srcset: string; sizes: string };
}
const {
  title = "Honeybee Atelier — Custom Celebration Cakes, Portland",
  description = "Boutique cake atelier in Portland, OR. Handcrafted couture wedding, birthday, and celebration cakes by a Certified Pastry Chef, plus cookies, cupcakes, and dessert tables for events.",
  active = "",
  jsonLd = [],
  stickyBar = true,
  manualHead = true,
  preloadImg,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {preloadImg && (
      <link rel="preload" as="image" imagesrcset={preloadImg.srcset} imagesizes={preloadImg.sizes} fetchpriority="high" />
    )}
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.png" />
    <slot name="seo-tags" />
    {manualHead && (
      <Fragment>
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
      </Fragment>
    )}
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@400;500&display=swap" />
    </noscript>
    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <Header active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CartDrawer client:only="react" />

    {stickyBar && (
      <div class="sticky-bar" aria-label="Quick order">
        <a href="/showcase" class="btn btn-primary">Order a cake</a>
        <a href="/build" class="btn btn-ghost">Build your own</a>
      </div>
    )}

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-in");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // mobile sticky order bar: only appears once you've scrolled past the hero
      const bar = document.querySelector(".sticky-bar");
      if (bar) {
        const upd = () => bar.classList.toggle("is-visible", window.scrollY > window.innerHeight * 0.6);
        window.addEventListener("scroll", upd, { passive: true });
        window.addEventListener("resize", upd, { passive: true });
        upd();
      }
    </script>
  </body>
</html>
